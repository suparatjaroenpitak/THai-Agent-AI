APP_URL="http://localhost:3000"
BETTER_AUTH_SECRET="development-secret-change-me"
DATABASE_URL="postgres://opencodex:opencodex@localhost:5432/opencodex"
REDIS_URL="redis://localhost:6379"

# Object storage (optional)
# Create in Cloudflare Dashboard: https://dash.cloudflare.com/?to=/:account/r2/overview
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="opencodex"
R2_PUBLIC_URL=""

# GitHub OAuth / App (optional until you enable GitHub login or GitHub automation)
# OAuth Apps: https://github.com/settings/developers
# GitHub Apps: https://github.com/settings/apps
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_APP_ID=""
GITHUB_APP_PRIVATE_KEY=""

# Default Chinese OpenAI-compatible provider.
# Provider keys can be entered in the in-app Models panel instead of this file.
DEFAULT_PROVIDER_BASE_URL="https://api.deepseek.com/v1"
DEFAULT_MODEL="deepseek-chat"

# Telemetry (optional unless you run a local OTLP collector)
OTEL_SERVICE_NAME="opencodex"
OTEL_EXPORTER_OTLP_ENDPOINT=""

# Worker sockets
WORKER_SHARED_SECRET="local-worker-secret"
WEBSOCKET_PORT="3001"
